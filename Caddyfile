# Caddy-Konfiguration – serviert die statische Seite auf dem von Railway gesetzten Port
:{$PORT:80} {
	root * /srv
	encode zstd gzip

	# Sicherheits-Header (gelten für alle Antworten)
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "SAMEORIGIN"
		# Nicht genutzte Browser-Features deaktivieren
		Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=(), usb=(), interest-cohort=()"
		-Server
	}

	# /index und /index.html sind Duplikate der Startseite -> direkt 301 auf die Wurzel
	redir /index.html / permanent
	redir /index / permanent

	# Abschliessenden Schraegstrich entfernen: /ratgeber/ lieferte bisher 404.
	# Externe Links und Direkteingaben mit Slash liefen damit ins Leere und
	# verschenkten Linkkraft. Die Wurzel "/" ist ausgenommen, weil das Muster
	# mindestens ein Zeichen vor dem Slash verlangt.
	@trailingslash path_regexp trailslash ^/(.+)/$
	redir @trailingslash /{re.trailslash.1} permanent

	# .html-Endungen dauerhaft auf die saubere URL umleiten (301, gegen Duplicate Content).
	# Die Bedingung "file" ist wichtig: ohne sie bekaeme JEDE .html-Anfrage einen 301,
	# auch geloeschte Seiten. Google liefe dann von der Weiterleitung in einen 404,
	# statt den 404 direkt zu sehen.
	@htmlext {
		path_regexp htmlext ^/(.+)\.html$
		file {path}
	}
	redir @htmlext /{re.htmlext.1} permanent

	# Saubere URLs intern zur .html-Datei auflösen: /reviews -> /reviews.html
	try_files {path} {path}/ {path}.html
	file_server

	# Bilder lange cachen (ändern sich selten)
	@media path *.png *.jpg *.jpeg *.svg *.ico *.webp *.gif
	header @media Cache-Control "public, max-age=604800"

	# Schriften ein Jahr cachen: die Dateien sind unveränderlich, ein Wechsel
	# bekäme ohnehin einen neuen Dateinamen. Spart wiederkehrenden Besuchern 192 KB.
	@fonts path *.woff2
	header @fonts Cache-Control "public, max-age=31536000, immutable"

	# CSS & JS immer neu prüfen, damit Design-Änderungen sofort ankommen
	@code path *.css *.js
	header @code Cache-Control "public, max-age=0, must-revalidate"
}
